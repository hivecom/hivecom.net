{
  "name": "hivecom",
  "type": "module",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "build": "nuxi build --preset github_pages",
    "reset": "npx supabase db reset && node scripts/seed-assets.js",
    "dev": "npx supabase start && nuxi dev",
    "dev:staging": "nuxi dev --dotenv .env.production",
    "dev:staging:host": "nuxi dev --dotenv .env.production --host",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "postinstall": "nuxi prepare",
    "supabase": "npx supabase",
    "types": "npx supabase gen types typescript --local --schema public,private > types/database.types.ts",
    "lint": "eslint . && nuxi typecheck",
    "lint:fix": "eslint . --fix && nuxi typecheck --fix",
    "analyze": "nuxi analyze"
  },
  "dependencies": {
