{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "paths": {
      "@/*": [
        "./app/*"
      ],
      "@/components/*": [
        "./app/components/*"
      ],
      "@/lib/*": [
        "./app/lib/*"
      ],
      "@/types/*": [
        "./types/*"
      ],
      "@/composables/*": [
        "./app/composables/*"
      ],
      "@/assets/*": [
        "./app/assets/*"
      ],
      "@/layouts/*": [
        "./app/layouts/*"
      ],
      "@/pages/*": [
        "./app/pages/*"
      ],
      "@/utils/*": [
        "./app/lib/utils/*"
      ],
      "~/*": [
        "./*"
      ],
      "~~/*": [
        "./*"
      ],
      "#imports": [
        "./.nuxt/imports.d.ts"
      ],
      "#app/nuxt": [
        "./node_modules/nuxt/dist/app/index"
      ]
    },
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "files": [
    "content.config.ts",
    "mdc.config.ts"
  ],
  "exclude": [
    "supabase"
  ]
}
